rived-at "2026-07-02T15:44:23.104413091Z", :entry-edn "{:discharged-by nil, :witness nil, :outcome-ref {:kind :goal, :referent nil, :metric :satisfied}, :static-risk 0.3, :flavour :reach, :weight {:value 0.3, :basis :default-unoriented}, :status :open, :preferred {:op :becomes, :value :reached}, :provenance {:source \":ying-voice-salvage\", :provisional true, :channel :ying-voice, :derived-from \"pair-0ce22e24\", :grounded-ref nil, :assistant-span \"Your bitshift model. ... So roles *cycle*; the influence isn’t a fixed one-way arrow, it’s a **sliding sequence of overlapping one-way windows** whose direction alternates each shift.\", :reply-span nil}}"}, :xt/id "016c6a73-6eba-4c77-ad94-c00461a702be"} {:entity/id "016d1f4d-025c-4558-a489-5afbafaca41f", :entity/name "iching/hexagram-36-mingyi", :entity/type :pattern/library, :entity/external-id "iching/hexagram-36-mingyi", :entity/source "䷣ 明夷 (Míng Yí) - Darkening of the Light", :xt/id "016d1f4d-025c-4558-a489-5afbafaca41f"} {:entity/id "016f8fd3-5f07-4cde-bc57-fd3f9e90de12", :entity/name "math-formalization/construction-cost-asymmetry/conclusion", :entity/type :pattern/clause, :entity/external-id "math-formalization/construction-cost-asymmetry/conclusion", :entity/source "When the mathematical insight is trivial but the Lean construction is\n  ~50+ lines of engineering, use witness templates rather than building\n  from scratch each time.", :xt/id "016f8fd3-5f07-4cde-bc57-fd3f9e90de12"} {:entity/id "017076e7-7e9d-47d2-bf2d-4933fcc1b54f", :entity/name "iiching/exotype-254", :entity/type :pattern/library, :entity/external-id "iiching/exotype-254", :entity/source "Exotype 254 (0xFE)", :xt/id "017076e7-7e9d-47d2-bf2d-4933fcc1b54f"} {:entity/id "01712d5f-af6c-4aec-8cb2-2c2fdc1f6ac4", :entity/name "futon-theory/xenotype-portability/conclusion", :entity/type :pattern/clause, :entity/external-id "futon-theory/xenotype-portability/conclusion", :entity/source "The xenotype makes Baldwin cycles themselves portable. The same\n  generate-select-compress skeleton can be reused at different interfaces,\n  turning cross-layer gain from accidental tuning into replicable structure.", :xt/id "01712d5f-af6c-4aec-8cb2-2c2fdc1f6ac4"} {:entity/id "01768371-a4f2-4fff-8045-fca576b96166", :entity/name "ai4ci/technical-grounding/07-status", :entity/type :pattern/component, :entity/external-id "STATUS", :entity/source "evidence[src/f2/router.clj:1]\n    evidence[docs/protocol.md:1]\n    status[ready]", :xt/id "01768371-a4f2-4fff-8045-fca576b96166"} {:entity/id "018f1e0c-7d3f-4e66-9b17-9d72fc23b289", :entity/name "iiching/exotype-201", :entity/type :pattern/library, :entity/external-id "iiching/exotype-201", :entity/source "Exotype 201 (0xC9)", :xt/id "018f1e0c-7d3f-4e66-9b17-9d72fc23b289"} {:entity/id "019076dd-8d0c-4f8c-b5fb-38103287985c", :entity/name "pacspine/quick-intro/04-however", :entity/type :pattern/component, :entity/external-id "however", :entity/source "Most letters waste this window reciting CVs.", :xt/id "019076dd-8d0c-4f8c-b5fb-38103287985c"} {:entity/id "0193855e-3f6e-409b-98bc-ad3840dc36ae", :entity/name "storage/durability-throughput-gate/if", :entity/type :pattern/clause, :entity/external-id "storage/durability-throughput-gate/if", :entity/source "you want throughput and responsive writes", :xt/id "0193855e-3f6e-409b-98bc-ad3840dc36ae"} {:entity/id "0193efd8-1d19-46ac-a6db-1def73ab9452", :entity/name "iiching/exotype-196", :entity/type :pattern/library, :entity/external-id "iiching/exotype-196", :entity/source "Exotype 196 (0xC4)", :xt/id "0193efd8-1d19-46ac-a6db-1def73ab9452"} {:entity/id "019bc8b1-fb1e-482d-8f3a-8ab8715070cf", :entity/name "agent/sense-deliberate-act/03-if", :entity/type :pattern/component, :entity/external-id "IF", :entity/source "The agent needs to make progress on a goal while responding to a changing environment.", :xt/id "019bc8b1-fb1e-482d-8f3a-8ab8715070cf"} {:entity/id "019c0987-5d46-4e44-9c75-7718e6dbcd7d", :entity/name "iiching/exotype-110/03-if", :entity/type :pattern/component, :entity/external-id "IF", :entity/source "You need an explicit, searchable exotype record.", :xt/id "019c0987-5d46-4e44-9c75-7718e6dbcd7d"} {:entity/id "019f379b-f44a-497e-a525-015d3645bd67", :entity/name "writing-coherence/missing-mechanism", :entity/type :pattern/library, :entity/external-id "writing-coherence/missing-mechanism", :entity/source "Name the Mechanism That Makes the Contrast Bite", :xt/id "019f379b-f44a-497e-a525-015d3645bd67"} {:entity/id "019faae3-bce3-45d9-9aff-6db5251870ff", :entity/name "iching/hexagram-43-guai/05-then", :entity/type :pattern/component, :entity/external-id "THEN", :entity/source "Act decisively, but with restraint and clarity.", :xt/id "019faae3-bce3-45d9-9aff-6db5251870ff"} {:entity/id "01a3904e-42a5-49c9-853f-6d2cbc4d61b8", :entity/name "ukrns/reader-as-participant/03-tension", :entity/type :pattern/component, :entity/external-id "TENSION", :entity/source "Axis: reader-as-consumer (receives conclusions; reads for information) ↔ reader-as-diagnostic-participant (is invited to pick a position; reads for decision).\n    Real: a consumer-oriented paper is faster to read, easier to cite, and respects the reader's time; a participant-oriented paper demands more of the reader and produces more friction.  Both orientations carry genuine costs.\n    Irreducible: the same section cannot simultaneously deliver a closed conclusion and invite an open choice.  A reader confronted with 'you must decide which composition you would run' has a different reading experience than one shown 'the authors recommend composition X'.\n    Active: the right orientation depends on the reader and the moment.  Early in a paper's lifecycle, when the argument is forming and the decision is genuinely open, participation is productive.  As claims harden and decisions are made, participation becomes performative (the reader is invited to agree with a choice already taken).  Audiences also differ: funders may want conclusions; institutional leads may need to participate; trainers may need to see themselves in the diagnosis.", :xt/id "01a3904e-42a5-49c9-853f-6d2cbc4d61b8"} {:entity/id "01a6861d-c1de-41f3-ac18-5bc4aed4ecbe", :entity/name "pacspine/future-field", :entity/type :pattern/library, :entity/external-id "pacspine/future-field", :entity/source "Pattern 6 — Get Them Excited (Open the Future Field)", :xt/id "01a6861d-c1de-41f3-ac18-5bc4aed4ecbe"} {:entity/id "01ab8038-33aa-4579-9cb3-07cf08201424", :entity/name "writing-coherence/unearned-essentially/if", :entity/type :pattern/clause, :entity/external-id "writing-coherence/unearned-essentially/if", :entity/source "The pattern operates on the axis: rhetorical force ↔ argumentative warrant.\n    Irreducible: the same adverb cannot simultaneously earn its collapse (reader has the derivation) and substitute for the derivation (reader does not).", :xt/id "01ab8038-33aa-4579-9cb3-07cf08201424"} {:entity/id "01ac0d88-5cb8-4576-8056-4d8c99e5df09", :entity/name "meta/layering-design-into-argument/because", :entity/type :pattern/clause, :entity/external-id "meta/layering-design-into-argument/because", :entity/source "When prose is downstream of patterns, the argument inherits their clarity and\n    the canon can detect overclaiming.", :xt/id "01ac0d88-5cb8-4576-8056-4d8c99e5df09"} {:entity/id "01aed222-fec9-4d89-afa6-50fe273b86ef", :entity/name "iiching/exotype-210/next-steps", :entity/type :pattern/clause, :entity/external-id "iiching/exotype-210/next-steps", :entity/source "- blocked-by[futon5-exotype-lift]\n\n@exotype-encoding\n  :bit-order :msb->lsb\n  :bits-b7..b0 [1 1 0 1 0 0 1 0]\n\n@exotype-program\n  :program-id :contextual-mutate+mix\n  :program-name \"contextual-mutate+mix\"\n  :program-kind :stochastic-kleisli\n  :tier :super\n  :scope :kernel-transformer\n  :inputs {:kernel-transformer [:kernel-spec :context :params :rng], :context-step [:history :rng]}\n  :outputs [:kernel-spec]\n  :invariants [:normalize :probabilistic-update]\n  :word-variation :by-tier\n  :notes \"From futon5/resources/exotype-program-manifest.edn.\"\n\n\n@exotype-lift\n  :pattern-ids []\n  :ct-template nil\n  :lift-rules nil\n  :evidence []\n  :notes \"No lift mapping for bits 11010010 in futon5/resources/exotype-xenotype-lift.edn.\"\n\n\n@exotype-params\n  :rotation 3\n  :match-threshold 0.3333333333333333\n  :invert-on-phenotype? false\n  :update-prob 0.75\n  :mix-mode :rotate-right\n  :mix-shift 2\n  :notes \"From futon5/resources/exotype-program-manifest.edn.\"", :xt/id "01aed222-fec9-4d89-afa6-50fe273b86ef"} {:entity/id "01b10b3f-bf72-4ffc-82e4-4ecdeae1421c", :entity/name "iiching/exotype-250/context", :entity/type :pattern/clause, :entity/external-id "iiching/exotype-250/context", :entity/source "Canonical 8-bit encoding for exotype 250.", :xt/id "01b10b3f-bf72-4ffc-82e4-4ecdeae1421c"} {:entity/id "01b36b4a-4ff3-4611-932c-47acf0f6eef5", :entity/name "iiching/exotype-061/04-however", :entity/type :pattern/component, :entity/external-id "HOWEVER", :entity/source "The lift registry records pattern bindings but no lift-rules.", :xt/id "01b36b4a-4ff3-4611-932c-47acf0f6eef5"} {:entity/id "01b4a608-2e4c-4ef6-813a-09f1fb5aa1ee", :entity/name "iiching/exotype-139/if", :entity/type :pattern/clause, :entity/external-id "iiching/exotype-139/if", :entity/source "You need an explicit, searchable exotype record.", :xt/id "01b4a608-2e4c-4ef6-813a-09f1fb5aa1ee"} {:entity/id "01b7406f-0e57-4cc5-b306-d9346f1fb02f", :entity/name "futon-theory/progress-signal", :entity/type :pattern/library, :entity/external-id "futon-theory/progress-signal", :entity/source "Progress Signal (Evidence Accumulation)", :xt/id "01b7406f-0e57-4cc5-b306-d9346f1fb02f"} {:entity/id "01ba24aa-21b0-462a-b042-ee49d7bacfe5", :entity/name "iiching/exotype-109/03-if", :entity/type :pattern/component, :entity/external-id "IF", :entity/source "You need an explicit, searchable exotype record.", :xt/id "01ba24aa-21b0-462a-b042-ee49d7bacfe5"} {:entity/id "01ba7486-1e15-4a27-a2e7-e407b715c909", :entity/name "iiching/exotype-235/context", :entity/type :pattern/clause, :entity/external-id "iiching/exotype-235/context", :entity/source "Canonical 8-bit encoding for exotype 235.", :xt/id "01ba7486-1e15-4a27-a2e7-e407b715c909"} {:entity/id "01c1ff7c-e44f-440f-9781-45f1102caafe", :entity/name "iiching/exotype-040", :entity/type :pattern/library, :entity/external-id "iiching/exotype-040", :entity/source "Exotype 040 (0x28)", :xt/id "01c1ff7c-e44f-440f-9781-45f1102caafe"} {:entity/id "01c92536-a537-4f67-9822-05162fe93fa6", :entity/name "peeragogy/heartbeat/if", :entity/type :pattern/clause, :entity/external-id "peeragogy/heartbeat/if", :entity/source "The pattern operates on the axis: coordination overhead ↔ attention maintenance.\n    Irreducible: a group cannot simultaneously be self-organising and rely on no recurring signal.  Even fully decentralised groups end up with implicit heartbeats (a recurring meeting, a shared release cadence); the only choice is whether the heartbeat is named.", :xt/id "01c92536-a537-4f67-9822-05162fe93fa6"} {:entity/id "01cbb88f-eedf-4062-a322-3ddaa141e35a", :entity/name "t4r/exec-summary-tree", :entity/type :pattern/library, :entity/external-id "t4r/exec-summary-tree", :entity/source "Executive Summary", :xt/id "01cbb88f-eedf-4062-a322-3ddaa141e35a"} {:entity/id "01cc44e2-754f-4f87-b532-142acb3e8d91", :entity/name "gauntlet/teaching-inversion/if", :entity/type :pattern/clause, :entity/external-id "gauntlet/teaching-inversion/if", :entity/source "You want the human-agent system to produce more knowledge than either party could alone, and you want the human to learn — not just supervise.", :xt/id "01cc44e2-754f-4f87-b532-142acb3e8d91"} {:entity/id "01d6a1b2-dd64-48a0-abc8-aa05dc3fcd5a", :entity/name "iiching/exotype-138/because", :entity/type :pattern/clause, :entity/external-id "iiching/exotype-138/because", :entity/source "Explicit encodings make exotype knowledge inspectable and comparable.", :xt/id "01d6a1b2-dd64-48a0-abc8-aa05dc3fcd5a"} {:entity/id "01d9da15-c027-43a2-8658-37d08eb19e97", :entity/name "p4ng/method-documentary-split/conclusion", :entity/type :pattern/clause, :entity/external-id "p4ng/method-documentary-split/conclusion", :entity/source "Separate method from documentary layer so the practice can evolve operationally without forcing every working note to carry the weight of final exposition.", :xt/id "01d9da15-c027-43a2-8658-37d08eb19e97"} {:entity/id "01e5d2e2-dba3-46e6-a2cd-8f187c06cf9d", :entity/name "iiching/exotype-075/04-however", :entity/type :pattern/component, :entity/external-id "HOWEVER", :entity/source "The lift registry records pattern bindings but no lift-rules.", :xt/id "01e5d2e2-dba3-46e6-a2cd-8f187c06cf9d"} {:entity/id "01e6a2da-70c6-402d-9d95-c2593c74f6e5", :entity/name "iiching/exotype-215", :entity/type :pattern/library, :entity/external-id "iiching/exotype-215", :entity/source "Exotype 215 (0xD7)", :xt/id "01e6a2da-70c6-402d-9d95-c2593c74f6e5"} {:entity/id "01ef21f4-4e05-4947-9d39-c2f2b19d08d1", :entity/name "iiching/exotype-197/05-then", :entity/type :pattern/component, :entity/external-id "THEN", :entity/source "program/params until lift mappings land.\n    Use the encoding fields for identification and the futon5 manifest for", :xt/id "01ef21f4-4e05-4947-9d39-c2f2b19d08d1"} {:entity/id "01ef7e04-10c1-4f95-868b-efc30667ea36", :entity/name "futon-theory/mission-dependency/context", :entity/type :pattern/clause, :entity/external-id "futon-theory/mission-dependency/context", :entity/source "Missions rarely exist in isolation. They block and enable each other,\n    share prerequisites, and compete for resources. Without explicit\n    dependency tracking, agents work on blocked missions or miss\n    opportunities to unblock others.", :xt/id "01ef7e04-10c1-4f95-868b-efc30667ea36"} {:entity/id "01f04de0-a8fb-4ecb-b841-830a77d6e0ae", :entity/name "writing-coherence/meta-lede/then", :entity/type :pattern/clause, :entity/external-id "writing-coherence/meta-lede/then", :entity/source "Operate an explicit move on the named axis (see substructure below); steward the pattern against the declared discipline.", :xt/id "01f04de0-a8fb-4ecb-b841-830a77d6e0ae"} {:entity/external-id "f2/p7", :entity/pinned? false, :entity/lower-label "f2/p7", :entity/updated-at #inst "2026-01-31T18:22:00.993000000-00:00", :entity/seen-count 3, :entity/name "f2/p7", :futon1a/backfill/orig-type :devmap/prototype, :entity/type :pattern/library, :entity/first-seen #inst "2026-01-31T18:22:00.993000000-00:00", :entity/source "futon3/devmap", :entity/id "01f221bc-9e6a-4843-aafc-1055e8cd42db", :entity/kind :devmap/prototype, :entity/label "f2/p7", :entity/last-seen 1769884132977, :xt/id "01f221bc-9e6a-4843-aafc-1055e8cd42db"} {:entity/id "01f94b7d-db40-4b73-b040-2d136dedd59b", :entity/name "math-informal/quotient-by-irrelevance/then", :entity/type :pattern/clause, :entity/external-id "math-informal/quotient-by-irrelevance/then", :entity/source "Define an equivalence relation that identifies objects agreeing on what matters. Pass to the\n      quotient. Verify well-definedness. Work in the quotient where the irrelevant distinctions\n      are gone.", :xt/id "01f94b7d-db40-4b73-b040-2d136dedd59b"} {:entity/id "01fb2de3-8731-4c40-b320-5f05f4abead9", :entity/name "iiching/exotype-172", :entity/type :pattern/library, :entity/external-id "iiching/exotype-172", :entity/source "Exotype 172 (0xAC)", :xt/id "01fb2de3-8731-4c40-b320-5f05f4abead9"} {:entity/id "01fbc726-cff4-41b8-a6af-66894d643a9c", :entity/name "software-design/facade-pattern/06-because", :entity/type :pattern/component, :entity/external-id "because", :entity/source "A stable facade shields callers from churn in underlying components.", :xt/id "01fbc726-cff4-41b8-a6af-66894d643a9c"}]}